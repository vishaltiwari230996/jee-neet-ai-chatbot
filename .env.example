# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NEETAI_ENV=local                  # local | dev | staging | prod
NEETAI_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
NEETAI_LOG_FORMAT=text             # text (dev) | json (prod)
NEETAI_API_HOST=0.0.0.0
NEETAI_API_PORT=8000

# ---------------------------------------------------------------------------
# Database — Postgres + pgvector (via docker-compose locally)
# ---------------------------------------------------------------------------
NEETAI_DATABASE_URL=postgresql+psycopg://neetai:neetai@localhost:55432/neetai

# ---------------------------------------------------------------------------
# Cache / queue — Redis (via docker-compose locally)
# ---------------------------------------------------------------------------
NEETAI_REDIS_URL=redis://localhost:56379/0

# ---------------------------------------------------------------------------
# LLM — OpenRouter (primary) with Anthropic-direct as a fallback adapter
# Pick provider via NEETAI_LLM_PROVIDER. Strong/cheap model slots are routed
# inside the application; do not hardcode model names in calling code.
# ---------------------------------------------------------------------------
NEETAI_LLM_PROVIDER=openrouter    # openrouter | anthropic | fake
NEETAI_LLM_STRONG_MODEL=anthropic/claude-sonnet-4.6   # 1M ctx, $3/M in, $15/M out
NEETAI_LLM_CHEAP_MODEL=anthropic/claude-haiku-4.5     # 200K ctx, $1/M in, $5/M out
NEETAI_LLM_EMBEDDING_MODEL=text-embedding-3-small
NEETAI_LLM_TIMEOUT_SECONDS=30
NEETAI_LLM_MAX_RETRIES=2

OPENROUTER_API_KEY=                # required when NEETAI_LLM_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=neetai
OPENROUTER_APP_URL=https://neetai.local

ANTHROPIC_API_KEY=                 # required when NEETAI_LLM_PROVIDER=anthropic

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
NEETAI_OTEL_ENABLED=false
NEETAI_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
NEETAI_SENTRY_DSN=

NEETAI_LANGFUSE_ENABLED=false
NEETAI_LANGFUSE_HOST=https://cloud.langfuse.com
NEETAI_LANGFUSE_PUBLIC_KEY=
NEETAI_LANGFUSE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Auth — Clerk (added in Phase 2)
# ---------------------------------------------------------------------------
NEETAI_AUTH_PROVIDER=fake          # fake | clerk
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_WEBHOOK_SIGNING_SECRET=       # Clerk webhook endpoint secret (whsec_...)

# ---------------------------------------------------------------------------
# Signup records — Clerk webhook -> Postgres + Google Sheet
# ---------------------------------------------------------------------------
SIGNUP_SHEET_ID=                    # e.g. 1xHLZEk6ydnOA71bhsOih_ItBUtg1Fklr8Q2m6se2SKw
SIGNUP_SHEET_TAB_NAME=Signups
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google-service-account.json
# Alternative to file path for hosted deploys:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
